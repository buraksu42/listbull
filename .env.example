# Copy to .env.local and fill in actual DEV values
# NEVER commit .env.local — production secrets live in Dokploy env vars

# ─── App ──────────────────────────────────────────────────────
# Public base URL of this deployment (used for webhook + Mini App URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment label (test/prod). Set NEXT_PUBLIC_ENV=test on test server to gate noindex.
NEXT_PUBLIC_ENV=development

# ─── Database (Postgres via Drizzle) ──────────────────────────
DATABASE_URL=postgres://listgram:listgram@localhost:5432/listgram

# ─── Auth (Better Auth) ───────────────────────────────────────
# Random ≥32-byte secret. Generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ─── BYOK key encryption ──────────────────────────────────────
# AES-256-GCM key (base64-encoded 32 bytes). Generate: openssl rand -base64 32
# Rotation = all stored OpenRouter keys unreadable; document re-prompt procedure.
ENV_KEY=

# ─── Telegram bot ─────────────────────────────────────────────
# Get from @BotFather → /newbot → token
TELEGRAM_BOT_TOKEN=
# Set on setWebhook; verify the X-Telegram-Bot-Api-Secret-Token header on every request.
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
# Bot username (without @). Used in deeplinks + share copy.
TELEGRAM_BOT_USERNAME=listgram_bot

# ─── LLM gateway (OpenRouter — BYOK; this is fallback for self-host operators) ──
# Optional: an operator-level key used only when a user has not set their own.
# Leave blank to require BYOK from every user.
# OPENROUTER_API_KEY=

# ─── Optional rate limit ──────────────────────────────────────
# Per-user hourly message cap for self-host operators worried about runaway costs.
# 0 (default) = disabled.
LISTGRAM_PER_USER_HOURLY_MSG_LIMIT=0

# ─── Optional heartbeat (Phase 3+) ────────────────────────────
# Better Stack heartbeat URL pinged by cron each minute.
# LISTGRAM_HEARTBEAT_URL=

# ─── Sentry (managed; build-time inlined) ─────────────────────
# Also must be set as Build Argument in Dokploy for Next 16 Turbopack inlining.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ─── Umami Analytics — shared instance (analytics.bullshitapps.com) ──
# Build-time inlined: must also be set as Build Argument in Dokploy.
# Wire via: ~/scripts/wire-umami.sh listgram
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
