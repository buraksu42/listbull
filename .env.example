# Copy to .env.local and fill in actual DEV values
# NEVER commit .env.local — production secrets live in Dokploy env vars

# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Database (if using direct Postgres via Drizzle) ─────────
DATABASE_URL=

# ─── LLM gateway (if project uses AI) ────────────────────────
# OPENROUTER_API_KEY=

# ─── Email (if project sends email) ──────────────────────────
# RESEND_API_KEY=

# ─── Umami Analytics — shared instance (analytics.bullshitapps.com) ──
# Build-time inlined: must also be set as Build Argument in Dokploy.
# See ~/projects/_templates/umami/README.md for setup.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
