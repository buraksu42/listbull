# listbull — environment variables.
#
# Copy this file to `.env.local` for local dev (chmod 600), or to `.env`
# for docker-compose (operator's responsibility). NEVER commit either —
# both are gitignored.
#
# Production secrets live in Dokploy environment variables, not in the
# repo. This file is the authoritative documentation of every variable
# `src/lib/env.ts` reads.

# ─── App ──────────────────────────────────────────────────────
# Public base URL of this deployment. Used in webhook callbacks,
# Mini App deeplinks, share-snapshot URLs. MUST be HTTPS in prod.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Environment label. Set to `test` on staging to gate noindex meta tag
# + test-only behavior. Common values: development | test | production.
NEXT_PUBLIC_ENV=development

# ─── Database (Postgres via Drizzle) ──────────────────────────
# Connection string. In docker-compose, the `app` service overrides
# this to `postgres://...@postgres:5432/...` (in-network host).
DATABASE_URL=postgres://listbull:listbull@localhost:5432/listbull

# Compose-only knobs (read by docker-compose.yml; ignored by Next.js).
POSTGRES_DB=listbull
POSTGRES_USER=listbull
POSTGRES_PASSWORD=listbull

# ─── Auth (Better Auth) ───────────────────────────────────────
# Random ≥32-byte secret used to sign session cookies + (fallback)
# snapshot URLs. Generate: `openssl rand -base64 48`.
BETTER_AUTH_SECRET=

# Public URL (same shape as NEXT_PUBLIC_APP_URL — Better Auth's
# canonical origin for cookie scope).
BETTER_AUTH_URL=http://localhost:3000

# ─── BYOK key encryption (Inv-8) ──────────────────────────────
# AES-256-GCM key for encrypting users' OpenRouter API keys at rest.
# 32-byte base64-encoded value. Generate: `openssl rand -base64 32`.
# ROTATION = every stored OpenRouter key becomes unreadable; document
# the re-prompt procedure in your runbook.
ENV_KEY=

# ─── Telegram bot ─────────────────────────────────────────────
# From @BotFather → /newbot → token. Treat as a secret.
TELEGRAM_BOT_TOKEN=

# Set on `setWebhook`; the webhook handler verifies the
# `X-Telegram-Bot-Api-Secret-Token` header on every request (Inv-9).
# Generate: `openssl rand -hex 32`.
TELEGRAM_WEBHOOK_SECRET=

# Bot username (without `@`). Used in deeplinks + share copy.
TELEGRAM_BOT_USERNAME=listbull_bot

# ─── LLM gateway (OpenRouter) ─────────────────────────────────
# OpenRouter is configured per-workspace via the Mini App settings,
# not via env. The workspace owner pastes their key in
# `Workspace settings → Workspace API key`; every member of that
# workspace uses it. There is no env-level OpenRouter key any more —
# operators who want multi-workspace shared spend should run a single
# workspace and invite users into it.

# ─── Per-user rate limit (operator safety net) ────────────────
# Hourly message cap PER user. Useful for self-host operators worried
# about runaway LLM costs. 0 (default) = disabled.
LISTBULL_PER_USER_HOURLY_MSG_LIMIT=0

# ─── Free-tier shared key (optional) ──────────────────────────
# When a chat has no OpenRouter key of its own, the bot falls back
# to this operator key + a free model — so users (e.g. group
# members opening a personal DM) can try the bot without setting up
# OpenRouter. Unset → keyless chats get the "add your key" prompt.
# LISTBULL_FREE_MODEL must be an OpenRouter `:free` model so the
# shared key incurs zero token cost. Voice STT is disabled on the
# free tier (it needs a paid audio model).
# LISTBULL_SHARED_OPENROUTER_KEY=
# LISTBULL_FREE_MODEL=deepseek/deepseek-v4-flash:free

# ─── Cron heartbeat (Phase 3+) ────────────────────────────────
# Optional Better Stack / Healthchecks.io heartbeat URL. Pinged each
# minute by the cron container.
#
# LIVENESS, NOT delivery health: fires when the dispatcher tick
# completes without throwing, regardless of per-row send success.
# Configure separate log-based alarms if delivery health matters
# operationally. See `src/lib/cron/dispatch-reminders.ts` (Inv-15).
# LISTBULL_HEARTBEAT_URL=

# ─── Snapshot URL signing (optional, Phase 4 / Inv-18) ────────
# Dedicated HMAC-SHA256 key for D2 shareable list snapshot URLs.
# When unset, falls back to BETTER_AUTH_SECRET (acceptable for small
# self-host operators; isolating signing keys is the defense-in-depth
# move). Generate: `openssl rand -base64 48`.
# SNAPSHOT_SIGNING_KEY=

# ─── Sentry (optional, build-time inlined) ────────────────────
# When set, the client bundle reports unhandled errors to Sentry.
# Build-time inlining: in Dokploy / docker-compose, these MUST also
# be passed as `buildArgs` so Next 16 Turbopack bakes them into the
# client chunks. Verify with:
#   curl https://<host>/_next/static/chunks/*.js | grep -E 'ingest\.(de\.)?sentry\.io|@sentry|sentryDsn'
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ─── Umami Analytics (optional, build-time inlined) ───────────
# Self-hosted privacy-friendly analytics. Wire via
# `~/scripts/wire-umami.sh listbull` (operator's local script —
# creates an Umami site + sets the build arg).
# Verify post-deploy: `curl -s https://<host>/ | grep analytics`.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
