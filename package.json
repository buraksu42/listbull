{
  "name": "listbull",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "cron": "tsx --tsconfig tsconfig.cron.json src/lib/cron/dispatch-reminders.ts",
    "setup:bot": "tsx --tsconfig tsconfig.cron.json scripts/setup-bot.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:list": "playwright test --list || test $? -eq 1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@sentry/nextjs": "^10.52.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.42.0",
    "next": "^16.2.6",
    "next-intl": "^4.11.0",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rrule": "^2.8.1",
    "server-only": "^0.0.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.4",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "kysely": "^0.28.17",
    "postcss": "^8.5.10",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    }
  }
}
