{
  "$schema": "https://design-tokens.org/format/v1",
  "brand": {
    "name": "listgram",
    "tagline": "Telegram-native AI list assistant"
  },
  "color": {
    "accent": {
      "teal":     { "value": "#00D9C0", "description": "Primary brand accent (default)" },
      "cobalt":   { "value": "#3D7DFF", "description": "Alternate accent — calm" },
      "marigold": { "value": "#F0A020", "description": "Alternate accent — warm" },
      "rose":     { "value": "#E5466F", "description": "Alternate accent — bold" }
    },
    "ink": {
      "deep":   { "value": "#0A1419", "description": "Brand ink — used as inverse/contrast on accent fills" },
      "black":  { "value": "#0A0A0A", "description": "Foreground on light surfaces" },
      "white":  { "value": "#FFFFFF", "description": "Foreground on accent and dark surfaces" }
    },
    "semantic": {
      "success":     { "value": "#2EB872" },
      "destructive": { "value": "#E53935" }
    },
    "theme": {
      "light": {
        "bg":          { "value": "#FFFFFF" },
        "fg":          { "value": "#0A0A0A" },
        "card":        { "value": "#F4F4F5" },
        "cardFg":      { "value": "#0A0A0A" },
        "muted":       { "value": "#F4F4F5" },
        "mutedFg":     { "value": "#707579" },
        "border":      { "value": "#E1E4E8" },
        "inputBg":     { "value": "#FFFFFF" },
        "subtle":      { "value": "#FAFAFA" },
        "destructive": { "value": "#E53935" },
        "success":     { "value": "#2EB872" },
        "accentFg":    { "value": "#FFFFFF", "description": "Foreground that sits on top of accent fills" }
      },
      "dark": {
        "bg":          { "value": "#17212B", "description": "Telegram dark default" },
        "fg":          { "value": "#F5F5F5" },
        "card":        { "value": "#232E3C" },
        "cardFg":      { "value": "#F5F5F5" },
        "muted":       { "value": "#232E3C" },
        "mutedFg":     { "value": "#708499" },
        "border":      { "value": "#2C3A4D" },
        "inputBg":     { "value": "#1B2735" },
        "subtle":      { "value": "#1C2734" },
        "destructive": { "value": "#FF5252" },
        "success":     { "value": "#4DD18C" },
        "accentFg":    { "value": "#0A1419", "description": "On dark theme, the check punches through to ink-deep" }
      }
    }
  },
  "font": {
    "family": {
      "sans":  { "value": "'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif", "description": "Body + UI" },
      "brand": { "value": "'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif", "description": "Wordmark · 700 weight, -0.02em tracking" }
    },
    "size": {
      "xs":  { "value": 11 },
      "sm":  { "value": 12 },
      "md":  { "value": 14, "description": "Body default" },
      "lg":  { "value": 16, "description": "Item titles" },
      "xl":  { "value": 18 },
      "2xl": { "value": 22 },
      "3xl": { "value": 28 },
      "4xl": { "value": 34, "description": "iOS large title" }
    },
    "weight": {
      "regular": { "value": 400 },
      "medium":  { "value": 500 },
      "semibold":{ "value": 600 },
      "bold":    { "value": 700 }
    },
    "letterSpacing": {
      "wordmark": { "value": "-0.02em" },
      "title":    { "value": "-0.01em" },
      "body":     { "value": "0" }
    }
  },
  "radius": {
    "sm":   { "value": 6 },
    "md":   { "value": 10 },
    "lg":   { "value": 14, "description": "Cards" },
    "xl":   { "value": 22, "description": "iOS appicon-style tiles" },
    "full": { "value": 9999, "description": "Pills, avatars, checkbox" }
  },
  "spacing": {
    "0": { "value": 0 },
    "1": { "value": 4 },
    "2": { "value": 8 },
    "3": { "value": 12 },
    "4": { "value": 16, "description": "Default screen padding" },
    "5": { "value": 20 },
    "6": { "value": 24 },
    "8": { "value": 32 },
    "10":{ "value": 40 },
    "12":{ "value": 48 }
  },
  "elevation": {
    "card":     { "value": "0 1px 2px rgba(10,20,25,0.04), 0 2px 8px rgba(10,20,25,0.04)" },
    "popover":  { "value": "0 8px 24px rgba(10,20,25,0.16)" },
    "sheet":    { "value": "0 -8px 24px rgba(10,20,25,0.18)" }
  },
  "motion": {
    "duration": {
      "fast":   { "value": "120ms" },
      "normal": { "value": "200ms" },
      "slow":   { "value": "320ms" }
    },
    "easing": {
      "standard": { "value": "cubic-bezier(0.2, 0, 0, 1)" },
      "emphasized": { "value": "cubic-bezier(0.3, 0, 0, 1)" }
    }
  },
  "size": {
    "checkbox":   { "value": 22 },
    "iconSm":     { "value": 16 },
    "iconMd":     { "value": 18 },
    "iconLg":     { "value": 24 },
    "avatar":     { "value": 28 },
    "tapTarget":  { "value": 44, "description": "Minimum hit area" },
    "headerH":    { "value": 52 }
  }
}
